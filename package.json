{
  "name": "apple-apps-mcp",
  "version": "0.1.0",
  "description": "Local MCP server and macOS setup app for Apple apps.",
  "type": "module",
  "bin": {
    "apple-apps-mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
